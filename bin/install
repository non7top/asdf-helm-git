#!/usr/bin/env bash

set -euo pipefail
shopt -s inherit_errexit 2>/dev/null || true

[[ -z ${ASDF_INSTALL_TYPE+x} ]] && echo "ASDF_INSTALL_TYPE is required" && exit 1
[[ -z ${ASDF_INSTALL_VERSION+x} ]] && echo "ASDF_INSTALL_VERSION is required" && exit 1
[[ -z ${ASDF_INSTALL_PATH+x} ]] && echo "ASDF_INSTALL_PATH is required" && exit 1

function install() {
	local install_type=$1
	[[ ${install_type} != "version" ]] && echo "install type, ${install_type}, is not supported" && exit 1

	local version=$2
	local install_path=$3

	local repo="aslafy-z/helm-git"
	local tag="v${version}"

	echo "Cloning ${repo} at ${tag} into ${install_path}"
	git clone --branch "${tag}" --depth 1 "https://github.com/${repo}" "${install_path}"

	if helm plugin list | sed 1d | grep -qs '^helm-git[[:space:]]'; then
		helm plugin uninstall helm-git
	fi
	helm plugin install "${install_path}"
}

install "${ASDF_INSTALL_TYPE}" "${ASDF_INSTALL_VERSION}" "${ASDF_INSTALL_PATH}"
